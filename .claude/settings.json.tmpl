{
  "awsAuthRefresh": "aws sso login --profile bedrock",
  "skillListingBudgetFraction": 0.04,
  "env": {
    "AWS_PROFILE": "bedrock",
    "AWS_REGION": "us-east-2",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "CLAUDE_CODE_WORKFLOWS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(fd *)",
      "Bash(find *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git merge-base *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git status *)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(make *)",
      "Bash(rg *)",
      "Bash(tail *)",
      "Bash(wc *)"
    ],
    "defaultMode": "plan"
  },
  "model": "arn:aws:bedrock:us-east-2:{{ op://Employee/AWS BedRock Account ID/password }}:inference-profile/global.anthropic.claude-opus-4-6-v1[1m]",
  "modelOverrides": {
    "claude-opus-4-8": "arn:aws:bedrock:us-east-2:{{ op://Employee/AWS BedRock Account ID/password }}:inference-profile/global.anthropic.claude-opus-4-8",
    "claude-opus-4-7": "arn:aws:bedrock:us-east-2:{{ op://Employee/AWS BedRock Account ID/password }}:inference-profile/global.anthropic.claude-opus-4-7",
    "claude-opus-4-6-1m": "arn:aws:bedrock:us-east-2:{{ op://Employee/AWS BedRock Account ID/password }}:inference-profile/global.anthropic.claude-opus-4-6-v1[1m]",
    "claude-opus-4-6": "arn:aws:bedrock:us-east-2:{{ op://Employee/AWS BedRock Account ID/password }}:inference-profile/global.anthropic.claude-opus-4-6-v1",
    "claude-opus-4-5": "arn:aws:bedrock:us-east-2:{{ op://Employee/AWS BedRock Account ID/password }}:inference-profile/global.anthropic.claude-opus-4-5-20251101-v1:0",
    "claude-opus-4-1": "arn:aws:bedrock:us-east-2:{{ op://Employee/AWS BedRock Account ID/password }}:inference-profile/global.anthropic.claude-opus-4-1-20250805-v1:0",
    "claude-sonnet-5": "arn:aws:bedrock:us-east-2:{{ op://Employee/AWS BedRock Account ID/password }}:inference-profile/global.anthropic.claude-sonnet-5",
    "claude-sonnet-4-6": "arn:aws:bedrock:us-east-2:{{ op://Employee/AWS BedRock Account ID/password }}:inference-profile/global.anthropic.claude-sonnet-4-6",
    "claude-sonnet-4-5": "arn:aws:bedrock:us-east-2:{{ op://Employee/AWS BedRock Account ID/password }}:inference-profile/global.anthropic.claude-sonnet-4-5-20250929-v1:0",
    "claude-sonnet-4": "arn:aws:bedrock:us-east-2:{{ op://Employee/AWS BedRock Account ID/password }}:inference-profile/global.anthropic.claude-sonnet-4-20250514-v1:0",
    "claude-haiku-4-5": "arn:aws:bedrock:us-east-2:{{ op://Employee/AWS BedRock Account ID/password }}:inference-profile/global.anthropic.claude-haiku-4-5-20251001-v1:0",
    "claude-3-5-haiku": "arn:aws:bedrock:us-east-2:{{ op://Employee/AWS BedRock Account ID/password }}:inference-profile/global.anthropic.claude-3-5-haiku-20241022-v1:0"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -message \"Claude Code needs your input\" -sound Sosumi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -message \"Claude Code finished\" -sound default"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/log-session-cost.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/scripts/statusline.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "insecure-defaults@trailofbits": true,
    "ask-questions-if-underspecified@trailofbits": true,
    "differential-review@trailofbits": true,
    "sharp-edges@trailofbits": true,
    "commit@fastly-agent-skills-internal": true,
    "delegate@fastly-agent-skills-internal": true,
    "google-workspace@fastly-agent-skills-internal": true,
    "is-it-safe-to-run@fastly-agent-skills-internal": true,
    "atlassian@claude-plugins-official": true,
    "code-review@fastly-agent-skills-internal": false,
    "fastly-agent-skills@fastly-agent-toolkit": true,
    "crit@crit": true
  },
  "extraKnownMarketplaces": {
    "fastly-agent-toolkit": {
      "source": {
        "source": "git",
        "url": "https://github.com/fastly/fastly-agent-toolkit.git"
      }
    },
    "crit": {
      "source": {
        "source": "github",
        "repo": "tomasz-tomczyk/crit"
      }
    }
  },
  "viewMode": "verbose",
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Thinking"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "showThinkingSummaries": true,
  "theme": "dark-ansi"
}
